# Application Settings
APP_NAME="Solar Monitoring System"
APP_VERSION="1.0.0"
DEBUG=True
LOG_LEVEL="INFO"

# Server Configuration
HOST="0.0.0.0"
PORT=8000

# MongoDB Configuration
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="solar_db"
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10

# Collections
COLLECTION_READINGS="readings_raw"
COLLECTION_PREDICTIONS="predictions"
COLLECTION_MODEL_RUNS="model_runs"

# ML Model Configuration
MODEL_DIR="app/ml_models"
MODEL_VERSIONS_DIR="app/ml_models/versions"
MODEL_CURRENT_POINTER="app/ml_models/current_model.json"

# Retraining Configuration
RETRAIN_ENABLED=True
RETRAIN_DAYS=7
RETRAIN_INTERVAL_HOURS=24
RETRAIN_TIME="18:30"
TIMEZONE="Asia/Colombo"
MAE_THRESHOLD_PERCENT=10.0

# CORS Settings (comma-separated origins)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# API Configuration
API_V1_PREFIX="/api"
MAX_QUERY_MINUTES=10080

# LLM Configuration (for /api/chat endpoints)
LLM_ENABLED=False
LLM_API_KEY="AIzaSyCW4wGkhUjhT92OmAnCeUQWwOWZewKDANY"
LLM_API_URL="https://generativelanguage.googleapis.com/v1beta/openai"
LLM_API_PATH="/chat/completions"
LLM_MODEL="gemini-3-flash-preview"
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=20
